# Copy this file to .env and fill in real values before starting.
#
# Generate secrets:
#   openssl rand -hex 32   → SECRET_KEY
#   openssl rand -hex 64   → JWT_SECRET

# ── Required ──────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
SECRET_KEY=
# REQUIRED — generate with: openssl rand -hex 64
JWT_SECRET=

# ── Database ───────────────────────────────────────────────────────────────────
# Docker Compose sets this automatically. Override here only if self-hosting
# outside Docker or pointing to an external DB.
# Default (Docker): sqlite+aiosqlite:////app/data/portal.db
# DATABASE_URL=sqlite+aiosqlite:////app/data/portal.db

# ── Timezone ──────────────────────────────────────────────────────────────────
# Timezone for shift times configured in the admin panel.
# Users receive notifications converted to their own profile timezone.
# Any IANA name: UTC, Europe/Moscow, Asia/Dubai, Europe/Berlin, etc.
PORTAL_TIMEZONE=UTC

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For local dev the default (localhost) is fine.
# For VPS/production, add your domain, e.g.:
#   CORS_ORIGINS=https://portal.example.com
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# Create a bot via @BotFather and paste the token here.
# Leave empty to disable all Telegram functionality.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ── Mail Reporter (optional) ──────────────────────────────────────────────────
# IMAP server settings — defaults work for Yandex 360.
# MAIL_IMAP_SERVER=imap.yandex.com
# MAIL_IMAP_PORT=993
# MAIL_IMAP_TIMEOUT=30
# How often (seconds) to poll all enabled mailboxes (default: 30).
# MAIL_POLL_INTERVAL=30
# Fallback Telegram chat_id when a mailbox has no telegram_target configured.
MAIL_DEFAULT_CHAT_ID=
# Fallback thread/topic id inside that chat (leave empty if not using forum topics).
MAIL_DEFAULT_THREAD_ID=
